# OpenClaw workspace .gitignore

# Agent skills installed via npx skills (symlinked, not source)
.agents/

# Node modules
node_modules/

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Temp task logs (auto-generated by watchdog system)
logs/tasks/

# Pipeline status files (auto-generated by pipeline monitor)
memory/pipelines/
